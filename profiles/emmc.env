# Standalone eMMC profile — production. The slot image's boot.img carries a
# fixed root=PARTLABEL=userdata cmdline (empty ramdisk, no initramfs); the
# KERNEL_CMDLINE below is consumed only by the dev-path onboard.sh.
#
# Display rotation: kernel `video=DSI-1:rotate=270` makes wlroots/cage see
# a 1280x800 landscape output; cage `-r` (single, set in tc8-rootfs's
# kiosk.service) gives the final viewing orientation. `fbcon=rotate:3`
# rotates the boot console text to match (needs
# CONFIG_FRAMEBUFFER_CONSOLE_ROTATION=y in kernel/tc8.config). Touch
# transform follows automatically. Verified end-to-end with
# tools/orient.html and tools/touch.html.
# console=tty0 last -> panel is the primary console: boot crawl + systemd
# status visible on the display (serial still mirrors everything).
KERNEL_CMDLINE="console=ttymxc1,115200 console=tty0 earlycon=ec_imx6q,0x30890000,115200 keep_bootcon panic=10 rw rootwait fw_devlink=permissive video=DSI-1:rotate=270 fbcon=rotate:3 systemd.show_status=true vt.global_cursor_default=0"
