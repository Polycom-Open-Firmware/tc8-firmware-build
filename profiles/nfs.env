# NFS-root profile — netboot target. Kernel mounts rootfs over NFSv3 from
# the configured server. Edit the IP and exported path to match your setup;
# the example below assumes the rootfs is unpacked at /srv/nfs/tc8-poly on
# 192.168.10.230 (tc8 LXC) and that export is rw to the panel's subnet.
KERNEL_CMDLINE="console=tty0 console=ttymxc1,115200 earlycon=ec_imx6q,0x30890000,115200 keep_bootcon panic=10 root=/dev/nfs nfsroot=192.168.10.230:/srv/nfs/tc8-poly,v3,tcp,nolock ip=:::::lan:dhcp rw rootwait fw_devlink=permissive"
