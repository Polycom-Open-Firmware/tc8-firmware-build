# C60 (Trio C60, kepler_proto1) target definition — same i.MX8MM SoC as TC8.
# Board delta consumed by build.sh --target=c60. M6. See PROFILES-PLAN.md.
# Boot geometry + AVB values are the PROVEN c60-firmware-build/profiles/emmc.env
# (what boots on C60 hardware) — do not "simplify" toward the TC8 numbers.
TARGET_NAME=c60
DTB_NAME=imx8mm-kepler-proto1.dtb
KERNEL_TARGET=c60                 # kernel/config.base + targets/c60.frag

# Kernel cmdline: root on system_a, i.MX8MM console.
C60_CMDLINE="console=tty0 console=ttymxc1,115200 earlycon=ec_imx6q,0x30890000,115200 panic=10 rw rootwait root=PARTLABEL=system_a"

# Rootfs lives in the stock `system_a` partition. HARD BUDGET: the image must
# fit — the builder REFUSES (never truncates) a rootfs bigger than this.
ROOTFS_PARTITION=system_a
ROOTFS_PARTITION_SIZE=1879048192  # 1.75 GiB stock system_a — hard ceiling
ROOTFS_IMG_DEFAULT_SIZE=1717986918 # 1.6 GiB — headroom-safe default

# boot geometry — i.MX8MM base; ramdisk/tags offsets are the C60 stock values
# (tags at 0x43400000 = stock fdt_addr_r; booti reads the DTB from boot.img's
# --second area at this address).
BOOT_PAGESIZE=2048
BOOT_BASE=0x40000000
BOOT_KERNEL_OFFSET=0x00080000     # kernel at 0x40080000
BOOT_RAMDISK_OFFSET=0x03000000    # 0x43000000
BOOT_TAGS_OFFSET=0x03400000       # 0x43400000 (stock fdt_addr_r)
BOOT_HEADER_VERSION=0
BOOT_PAD_SIZE=33554432            # 32 MiB content cap before AVB footer

# stock C60 GPT partition sizes (for the AVB footers / vbmeta):
BOOT_PARTITION_SIZE=50331648      # 48 MiB — boot_a/_b
DTBO_PARTITION_SIZE=4194304       # 4 MiB — dtbo_a/_b
VBMETA_PARTITION_SIZE=1048576     # 1 MiB — vbmeta_a/_b

# C60 AVB IS signed (SHA256_RSA2048), unlike TC8's unsigned NONE. The board is
# HAB-open so the signature isn't fused-verified, but stock u-boot's boota
# still requires structurally-signed vbmeta chaining BOTH boot + dtbo.
AVB_ALGORITHM=SHA256_RSA2048

# Boot model: C60 boots via booti + system_a; TC8 via boota A/B slots. These
# genuinely differ — the composer dispatches on BOOT_MODEL to a per-target
# boot recipe (clean separation, NOT a forced boota/booti abstraction).
BOOT_MODEL=booti
