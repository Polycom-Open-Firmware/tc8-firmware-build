# C60 (Trio C60, kepler_proto1) target definition — same i.MX8MM SoC as TC8.
# Board delta consumed by build.sh --target=c60. M6. See PROFILES-PLAN.md.
TARGET_NAME=c60
DTB_NAME=imx8mm-kepler-proto1.dtb
KERNEL_TARGET=c60                 # kernel/config.base + targets/c60.frag

# Rootfs lives in the stock `system_a` partition. HARD BUDGET: the image must
# fit — the builder REFUSES (never truncates) a rootfs bigger than this.
ROOTFS_PARTITION=system_a
ROOTFS_PARTITION_SIZE=1879048192  # 1.75 GiB stock system_a — hard ceiling
ROOTFS_IMG_DEFAULT_SIZE=1717986918 # 1.6 GiB — headroom-safe default

# boot geometry — same i.MX8MM base as TC8.
BOOT_PAGESIZE=2048
BOOT_BASE=0x40000000
BOOT_KERNEL_OFFSET=0x00080000
BOOT_RAMDISK_OFFSET=0x01000000
BOOT_TAGS_OFFSET=0x00000100

# Boot model: C60 boots via booti + system_a; TC8 via boota A/B slots. These
# genuinely differ — the composer dispatches on BOOT_MODEL to a per-target
# boot recipe (clean separation, NOT a forced boota/booti abstraction).
BOOT_MODEL=booti
