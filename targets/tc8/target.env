# TC8 target definition (board delta consumed by build.sh --target=tc8).
# One-project-two-targets, M6. See PROFILES-PLAN.md.
TARGET_NAME=tc8
DTB_NAME=imx8mm-tc8.dtb
KERNEL_TARGET=tc8                 # kernel/config.base + targets/tc8.frag

# Rootfs lives in the stock `userdata` partition (A/B Android layout, booted
# by NXP boota). Comfortable budget.
ROOTFS_PARTITION=userdata
ROOTFS_PARTITION_SIZE=6843006976  # 6.4 GiB — hard mount ceiling
ROOTFS_IMG_DEFAULT_SIZE=6843006976

# boot.img (Android v0) geometry — matches stock so boota accepts it.
BOOT_PAGESIZE=2048
BOOT_BASE=0x40000000
BOOT_KERNEL_OFFSET=0x00080000
BOOT_RAMDISK_OFFSET=0x01000000
BOOT_TAGS_OFFSET=0x00000100

# Boot model: boota A/B slot images (boot.img + dtbo.img + vbmeta.img).
BOOT_MODEL=boota

# boota slot partition sizes (avbtool add_hash_footer grows to these exactly).
BOOT_PARTITION_SIZE=50331648   # boot_a = 98304 sectors (48 MiB)
DTBO_PARTITION_SIZE=4194304    # dtbo_a = 8192 sectors (4 MiB)
